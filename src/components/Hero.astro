---
import SanityImage from './SanityImage.astro';
import type { HeroImage } from '../lib/queries';

interface Props {
  heroImages: HeroImage[];
}

const { heroImages = [] } = Astro.props;

const SOCIALS = [
  {
    href: 'https://www.facebook.com/cinekfilm',
    label: 'Facebook',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.563 9.876v-6.988h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.888h-2.33v6.988A10.003 10.003 0 0 0 22 12Z"/></svg>`,
  },
  {
    href: 'https://www.youtube.com/channel/UCAOcpcCJ753yKD9oAgvQdww',
    label: 'YouTube',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>`,
  },
  {
    href: 'https://www.instagram.com/cinek_film/',
    label: 'Instagram',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>`,
  },
  {
    href: 'https://twitter.com/cinekfilm',
    label: 'X (Twitter)',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
];
---

<section class="hero" id="hero">
  {heroImages.map((img, i) => (
    <div class:list={['hero-slide', { 'is-active': i === 0 }]} data-hero-slide>
      <SanityImage
        image={img.image}
        alt={img.title ?? ''}
        loading={i === 0 ? 'eager' : 'lazy'}
        sizes="100vw"
        widths={[800, 1200, 1920, 2400]}
        maxWidth={2400}
        aspect={16 / 9}
      />
    </div>
  ))}

  <div class="hero-grad-v" aria-hidden="true"></div>
  <div class="hero-grad-h" aria-hidden="true"></div>

  {heroImages.length > 1 && (
    <div class="hero-dots" aria-hidden="true">
      {heroImages.map((_, i) => (
        <button class:list={['hero-dot', { 'is-active': i === 0 }]} data-hero-dot={i} />
      ))}
    </div>
  )}

  <div class="hero-socials" aria-label="Sosyal medya linkleri">
    {SOCIALS.map(({ href, label, icon }) => (
      <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label} class="hero-social-link">
        <Fragment set:html={icon} />
      </a>
    ))}
  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>('[data-hero-slide]');
  const dots = document.querySelectorAll<HTMLElement>('[data-hero-dot]');
  if (slides.length >= 2) {

  let current = 0;

  function goTo(idx: number) {
    slides[current].classList.remove('is-active');
    dots[current]?.classList.remove('is-active');
    current = idx;
    slides[current].classList.add('is-active');
    dots[current]?.classList.add('is-active');
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const idx = parseInt(dot.dataset.heroDot ?? '0', 10);
      goTo(idx);
      resetTimer();
    });
  });

  let timer = setInterval(() => goTo((current + 1) % slides.length), 10000);
  function resetTimer() {
    clearInterval(timer);
    timer = setInterval(() => goTo((current + 1) % slides.length), 10000);
  }
  } // end slides.length >= 2
</script>

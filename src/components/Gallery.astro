---
import { urlFor } from '../lib/image';
import type { GalleryProject } from '../lib/queries';

interface Props {
  projects: GalleryProject[];
}

const { projects = [] } = Astro.props;

function formatDate(iso?: string): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long' });
}

// Keep only projects that actually have images to show.
const folders = projects
  .map((project) => {
    const images = (project.images ?? []).filter((img) => img.asset);
    const heading = project.title || project.filmTitle || '';
    const cover = images[0];
    const slides = images.map((img) => ({
      full: urlFor(img).width(1920).auto('format').url(),
      caption: img.caption ?? img.alt ?? '',
    }));
    return {
      heading,
      filmTitle: project.filmTitle && project.filmTitle !== heading ? project.filmTitle : '',
      date: formatDate(project.date),
      count: images.length,
      cover,
      coverLqip: cover?.asset?.metadata?.lqip,
      coverUrl: cover ? urlFor(cover).width(800).height(560).fit('crop').auto('format').url() : '',
      slides,
    };
  })
  .filter((f) => f.count > 0);
---

<section class="gallery-folders reveal">
  <div class="gallery-viewport">
    <div class="embla" data-gallery-carousel>
      <div class="embla__container">
        {folders.map((folder) => (
          <div class="embla__slide gallery-slide">
            <button
              class="gallery-folder"
              data-slides={JSON.stringify(folder.slides)}
              aria-label={`${folder.heading} — ${folder.count} fotoğraf`}
            >
              <div class="gallery-folder__cover">
                <img
                  src={folder.coverUrl}
                  alt={folder.cover?.alt ?? folder.heading}
                  loading="lazy"
                  decoding="async"
                  style={
                    folder.coverLqip
                      ? `background-image:url(${folder.coverLqip});background-size:cover;background-position:center;`
                      : undefined
                  }
                />
                <span class="gallery-folder__count">
                  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                  {folder.count}
                </span>
                <div class="gallery-folder__overlay"></div>
              </div>
              <div class="gallery-folder__info">
                <span class="gallery-folder__title">{folder.heading}</span>
                {(folder.filmTitle || folder.date) && (
                  <span class="gallery-folder__meta">
                    {[folder.filmTitle, folder.date].filter(Boolean).join(' · ')}
                  </span>
                )}
              </div>
            </button>
          </div>
        ))}
      </div>
    </div>
    <button class="carousel-btn carousel-btn--prev" aria-label="Önceki" data-gallery-prev>‹</button>
    <button class="carousel-btn carousel-btn--next" aria-label="Sonraki" data-gallery-next>›</button>
  </div>
</section>

<!-- Shared lightbox — populated per folder on click -->
<div class="lightbox" id="lightbox" aria-modal="true" role="dialog" aria-label="Fotoğraf görüntüleyici">
  <button class="lightbox__close" id="lightbox-close" aria-label="Kapat">✕</button>
  <button class="lightbox__nav lightbox__nav--prev" id="lightbox-prev" aria-label="Önceki">‹</button>
  <figure class="lightbox__figure">
    <img class="lightbox__img" id="lightbox-img" src="" alt="" />
    <figcaption class="lightbox__caption" id="lightbox-caption"></figcaption>
  </figure>
  <button class="lightbox__nav lightbox__nav--next" id="lightbox-next" aria-label="Sonraki">›</button>
</div>

<script>
  import EmblaCarousel from 'embla-carousel';
  import { addWheelScroll } from '../lib/carousel';

  // ---- Folder carousel ----
  const emblaNode = document.querySelector<HTMLElement>('[data-gallery-carousel]');
  if (emblaNode) {
    const viewport = emblaNode.closest<HTMLElement>('.gallery-viewport')!;
    const prevBtn = viewport.querySelector<HTMLButtonElement>('[data-gallery-prev]');
    const nextBtn = viewport.querySelector<HTMLButtonElement>('[data-gallery-next]');

    const carousel = EmblaCarousel(emblaNode, {
      align: 'start',
      dragFree: true,
      containScroll: 'keepSnaps',
      skipSnaps: true,
    });

    addWheelScroll(emblaNode, carousel);

    function updateBtns() {
      if (prevBtn) prevBtn.disabled = !carousel.canScrollPrev();
      if (nextBtn) nextBtn.disabled = !carousel.canScrollNext();
    }
    prevBtn?.addEventListener('click', () => carousel.scrollPrev());
    nextBtn?.addEventListener('click', () => carousel.scrollNext());
    carousel.on('select', updateBtns);
    carousel.on('reInit', updateBtns);
    updateBtns();
  }

  // ---- Lightbox (scoped to the clicked folder) ----
  type Slide = { full: string; caption: string };

  const lightbox = document.getElementById('lightbox')!;
  const imgEl = document.getElementById('lightbox-img') as HTMLImageElement;
  const captionEl = document.getElementById('lightbox-caption')!;
  const closeBtn = document.getElementById('lightbox-close')!;
  const prevBtn = document.getElementById('lightbox-prev')!;
  const nextBtn = document.getElementById('lightbox-next')!;

  let slides: Slide[] = [];
  let current = 0;

  function show(index: number) {
    if (!slides.length) return;
    current = (index + slides.length) % slides.length;
    const slide = slides[current];
    imgEl.src = slide.full;
    imgEl.alt = slide.caption;
    captionEl.textContent = slide.caption;
    captionEl.style.display = slide.caption ? '' : 'none';
  }

  function open(folderSlides: Slide[]) {
    slides = folderSlides;
    const multiple = slides.length > 1;
    prevBtn.style.display = multiple ? '' : 'none';
    nextBtn.style.display = multiple ? '' : 'none';
    show(0);
    lightbox.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox.classList.remove('is-open');
    document.body.style.overflow = '';
    imgEl.src = '';
    slides = [];
  }

  document.querySelectorAll<HTMLButtonElement>('.gallery-folder').forEach((folder) => {
    folder.addEventListener('click', () => {
      try {
        open(JSON.parse(folder.dataset.slides ?? '[]'));
      } catch { /* noop */ }
    });
  });

  closeBtn.addEventListener('click', close);
  prevBtn.addEventListener('click', () => show(current - 1));
  nextBtn.addEventListener('click', () => show(current + 1));

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('is-open')) return;
    if (e.key === 'Escape') close();
    else if (e.key === 'ArrowLeft' && slides.length > 1) show(current - 1);
    else if (e.key === 'ArrowRight' && slides.length > 1) show(current + 1);
  });
</script>
